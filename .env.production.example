# Copy this file to .env.production on the server and fill real secrets there.
# Do not commit the populated .env.production file.

AUTH_SECRET=replace-with-a-long-random-token

POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=agent_db

# LLM / embedding provider keys used by the existing agents.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=

# OCR for imported article images.
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# Optional observability.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
